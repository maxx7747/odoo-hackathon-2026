# Copy this file to .env and adjust as needed (optional for local dev — the
# app runs fine with the built-in defaults below if you skip this entirely).

DJANGO_SECRET_KEY=change-me-to-a-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
