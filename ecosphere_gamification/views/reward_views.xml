<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_reward_tree" model="ir.ui.view">
        <field name="name">esg.reward.tree</field>
        <field name="model">esg.reward</field>

        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="points_required"/>
                <field name="stock"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_reward_form" model="ir.ui.view">
        <field name="name">esg.reward.form</field>
        <field name="model">esg.reward</field>

        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="points_required"/>
                        <field name="stock"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_reward" model="ir.actions.act_window">
        <field name="name">Rewards</field>
        <field name="res_model">esg.reward</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>