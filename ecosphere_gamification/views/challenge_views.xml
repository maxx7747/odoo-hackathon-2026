<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_challenge_tree" model="ir.ui.view">
        <field name="name">esg.challenge.tree</field>
        <field name="model">esg.challenge</field>

        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="xp"/>
                <field name="difficulty"/>
                <field name="deadline"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_challenge_form" model="ir.ui.view">
        <field name="name">esg.challenge.form</field>
        <field name="model">esg.challenge</field>

        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="xp"/>
                        <field name="difficulty"/>
                        <field name="deadline"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_challenge" model="ir.actions.act_window">
        <field name="name">Challenges</field>
        <field name="res_model">esg.challenge</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>