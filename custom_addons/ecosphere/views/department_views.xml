<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="department_tree_view" model="ir.ui.view">
        <field name="name">ecosphere.department.tree</field>
        <field name="model">ecosphere.department</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="head"/>
                <field name="employee_count"/>
                <field name="total_score"/>
            </tree>
        </field>
    </record>

    <record id="department_form_view" model="ir.ui.view">
        <field name="name">ecosphere.department.form</field>
        <field name="model">ecosphere.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="head"/>
                        <field name="employee_count"/>
                    </group>

                    <group string="ESG Scores">
                        <field name="environmental_score"/>
                        <field name="social_score"/>
                        <field name="governance_score"/>
                        <field name="total_score"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>