<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_environment_tree" model="ir.ui.view">
        <field name="name">ecosphere.environment.tree</field>
        <field name="model">ecosphere.environment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="department_id"/>
                <field name="emission"/>
                <field name="target"/>
                <field name="date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_environment_form" model="ir.ui.view">
        <field name="name">ecosphere.environment.form</field>
        <field name="model">ecosphere.environment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="department_id"/>
                        <field name="emission"/>
                        <field name="target"/>
                        <field name="date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>